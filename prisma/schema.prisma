generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String
  name                String
  role                Role     @default(USER)
  resetToken          String?  @unique
  resetTokenExpiry    DateTime?
  googleClientId      String?
  googleClientSecret  String?
  googleAccessToken   String?
  googleRefreshToken  String?
  googleExpiresAt     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  orders              Order[]
  customers           Customer[]

  @@map("user")
}

enum Role {
  USER
  ADMIN
}

model Domain {
  id                     String       @id @default(cuid())
  extension              String       @unique
  price                  Int
  isActive               Boolean      @default(true)
  label                  DomainLabel?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  orders                 Order[]
  packagesWithFreeDomain Package[]    @relation("PackageFreeDomains")

  @@map("domain")
}

enum DomainLabel {
  POPULAR
  BEST_SELLER
  PROMO
}

model Template {
  id          String   @id @default(cuid())
  name        String
  thumbnail   String?
  previewUrl  String?
  category    String
  price       Int      @default(0)
  isPaid      Boolean  @default(false)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  packagesWithFreeTemplate Package[] @relation("PackageFreeTemplates")

  @@map("template")
}

model Package {
  id              String   @id @default(cuid())
  name            String
  price           Int      // Legacy price field (for 1 tahun)
  price1Year      Int?     // Price for 1 year
  price2Year      Int?     // Price for 2 years
  price3Year      Int?     // Price for 3 years
  duration        Int
  features        String   @db.Text
  isPopular       Boolean  @default(false)
  freeDomain      Boolean  @default(false)
  freeDomains     Domain[] @relation("PackageFreeDomains")
  freeTemplate    Boolean  @default(false)
  freeTemplates   Template[] @relation("PackageFreeTemplates")
  discountBadge   String?  // E.g., "90% OFF", "Limited Promo"
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orders          Order[]

  @@map("package")
}

model Service {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  price       Int
  priceType   PriceType   @default(ONE_TIME)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderService[]

  @@map("service")
}

enum PriceType {
  ONE_TIME
  PER_YEAR
  MONTHLY
}

model Promo {
  id              String    @id @default(cuid())
  code            String    @unique
  discountType    DiscountType
  discountValue   Int
  minTransaction  Int       @default(0)
  maxDiscount     Int?
  expiredAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orders          Order[]

  @@map("promo")
}

enum DiscountType {
  PERCENT
  NOMINAL
}

model Order {
  id              String         @id @default(cuid())
  invoiceId       String         @unique
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  domainName      String
  domainId        String
  domain          Domain         @relation(fields: [domainId], references: [id])
  templateId      String?
  template        Template?      @relation(fields: [templateId], references: [id])
  packageId       String?
  package         Package?       @relation(fields: [packageId], references: [id])
  promoId         String?
  promo           Promo?         @relation(fields: [promoId], references: [id])
  services        OrderService[]
  customerName    String
  customerEmail   String
  customerPhone   String
  subtotal        Int
  discount        Int            @default(0)
  total           Int
  status          OrderStatus    @default(PENDING)
  paymentMethod   String?
  paymentRef      String?
  paidAt          DateTime?
  expiredAt       DateTime?
  websiteUsername String?        // Login credentials for customer
  websitePassword String?        // Login credentials for customer
  loginUrl        String?        // Direct login link
  websiteEmail    String?        // Email for website access
  notes           String?        @db.Text // Admin notes for order progress
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("order")
}

model OrderService {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  price     Int

  @@unique([orderId, serviceId])
  @@map("orderservice")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
}

model SiteSetting {
  id              String   @id @default(cuid())
  siteName        String   @default("Website Pesan Jasa")
  siteTitle       String   @default("Jasa Pembuatan Website Profesional")
  siteDescription String?  @db.Text
  favicon         String?
  logo            String?
  contactEmail    String?
  contactPhone    String?
  contactAddress  String?  @db.Text
  socialFacebook  String?
  socialInstagram String?
  socialTwitter   String?
  socialWhatsapp  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sitesetting")
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String
  name      String
  company   String?
  address   String?  @db.Text
  whatsapp  String?              // NEW
  notes     String?  @db.Text    // NEW
  status    ClientStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  domains   ClientDomain[]
  servers   ClientServer[]
  user      User?          @relation(fields: [userId], references: [id])
  userId    String?        // Link to system user (optional)

  @@map("customer")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model ClientDomain {
  id              String        @id @default(cuid())
  clientEmail     String
  client          Customer      @relation(fields: [clientEmail], references: [email], onDelete: Cascade)
  domainName      String        @unique
  registrar       String?       // Deprecated, use relation below
  registrarId     String?
  registrarRel    DomainRegistrar? @relation(fields: [registrarId], references: [id])
  
  registeredAt    DateTime
  expiredAt       DateTime
  status          DomainStatus  @default(ACTIVE)
  autoRenew       Boolean       @default(false)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  servers         DomainServer[]
  
  @@index([clientEmail])
  @@index([registrarId])
  @@map("clientdomain")
}

model DomainRegistrar {
  id        String   @id @default(cuid())
  name      String
  username  String?
  password  String?
  loginUrl  String?
  expiredAt DateTime?
  notes     String?   @db.Text
  isActive  Boolean   @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  domains   ClientDomain[]

  @@map("domainregistrar")
}

enum DomainStatus {
  ACTIVE
  EXPIRED
  PENDING
  SUSPENDED
}

model ClientServer {
  id            String       @id @default(cuid())
  clientEmail   String
  client        Customer     @relation(fields: [clientEmail], references: [email], onDelete: Cascade)
  serverName    String
  ipAddress     String       // Removed unique to allow sharing IPs if needed, or keep unique if strict
  location      String
  serverType    ServerType
  status        ServerStatus @default(ACTIVE)
  expiredAt     DateTime?
  
  // NEW FIELDS
  username      String?
  password      String?      // Should be encrypted in app logic
  loginUrl      String?
  notes         String?      @db.Text

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  // Relations
  domains       DomainServer[]
  
  @@index([clientEmail])
  @@map("clientserver")
}

enum ServerType {
  SHARED
  VPS
  DEDICATED
  CLOUD
}

enum ServerStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model DomainServer {
  id        String        @id @default(cuid())
  domainId  String
  domain    ClientDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  serverId  String
  server    ClientServer  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
  
  @@unique([domainId, serverId])
  @@map("domainserver")
}
